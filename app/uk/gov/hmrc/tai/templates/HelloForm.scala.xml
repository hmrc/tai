<fo:root xmlns:fo="http://www.w3.org/1999/XSL/Format" language="en" font-size="11px" font-family="OpenSans">

  <fo:layout-master-set>
    <fo:simple-page-master master-name="main_template" page-height="297mm" page-width="210mm" margin="1in">
      <fo:region-body region-name="xsl-region-body" margin-top="12mm"/>
      <fo:region-before region-name="xsl-region-before" extent="12mm"/>
    </fo:simple-page-master>
  </fo:layout-master-set>

  <fo:page-sequence master-reference="main_template">

    <fo:static-content flow-name="xsl-region-before">
      <fo:block>
        <fo:block font-size="10px">HM Revenue &amp; Customs</fo:block>
        <fo:block font-size="10px" color="grey">Internal HMRC Copy</fo:block>
      </fo:block>
    </fo:static-content>

    <fo:flow flow-name="xsl-region-body">

      <fo:block font-size="14px" font-family="OpenSansBold" margin-bottom="4mm">Tell us about income from employment or pension</fo:block>
      <fo:block font-size="13px" font-family="OpenSansBold" margin-bottom="4mm">Internal Information</fo:block>
      <fo:block font-size="12px" font-family="OpenSansBold" margin-bottom="0mm">Summary</fo:block>

      <fo:block margin-bottom="5mm">
        <fo:block font-size="11px" font-family="OpenSansBold" margin-bottom="3mm">Tell us somethingt</fo:block>
        <fo:block>Hello World</fo:block>
        <fo:block hyphenate="true" background-color="gray">ThequickbrownfoxjumpsoverthelazydogThequickbrownfoxjumpsoverthelazydogThequickbrownfoxjumpsoverthelazydog</fo:block>
      </fo:block>
    </fo:flow>
  </fo:page-sequence>
</fo:root>
